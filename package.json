{
  "name": "nest",
  "private": true,
  "workspaces": [
    "apps/api",
    "apps/worker",
    "apps/web"
  ],
  "scripts": {
    "dev:api": "npm run dev -w apps/api",
    "dev:worker": "npm run dev -w apps/worker",
    "dev:web": "npm run dev -w apps/web",
    "build": "npm run build -w apps/api && npm run build -w apps/worker && npm run build -w apps/web",
    "db:migrate": "psql -h ${POSTGRES_HOST:-127.0.0.1} -p ${POSTGRES_PORT:-5432} -U ${POSTGRES_USER:-nest} -d ${POSTGRES_DB:-nest} -f apps/api/db/schema.sql",
    "db:seed": "psql -h ${POSTGRES_HOST:-127.0.0.1} -p ${POSTGRES_PORT:-5432} -U ${POSTGRES_USER:-nest} -d ${POSTGRES_DB:-nest} -f apps/api/db/seed.sql"
  }
}
